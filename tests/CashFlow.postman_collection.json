{
  "info": {
    "name": "Daily Cash Flow APIs",
    "description": "Collection para testar as APIs de Transactions e Consolidation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Transactions API",
      "item": [
        {
          "name": "Health - Live",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{transactions_url}}/health/live",
              "host": [
                "{{transactions_url}}"
              ],
              "path": [
                "health",
                "live"
              ]
            }
          }
        },
        {
          "name": "Health - Ready",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{transactions_url}}/health/ready",
              "host": [
                "{{transactions_url}}"
              ],
              "path": [
                "health",
                "ready"
              ]
            }
          }
        },
        {
          "name": "Create Transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"Credit\",\n  \"amount\": 150.0,\n  \"occurredOn\": \"2026-04-28T12:00:00Z\",\n  \"currency\": \"BRL\",\n  \"description\": \"Venda de produto\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{transactions_url}}/transactions",
              "host": [
                "{{transactions_url}}"
              ],
              "path": [
                "transactions"
              ]
            }
          }
        },
        {
          "name": "Get Transaction",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{transactions_url}}/transactions/{{transaction_id}}",
              "host": [
                "{{transactions_url}}"
              ],
              "path": [
                "transactions",
                "{{transaction_id}}"
              ]
            }
          }
        },
        {
          "name": "Reverse Transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Cliente solicitou estorno\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{transactions_url}}/transactions/{{transaction_id}}/reverse",
              "host": [
                "{{transactions_url}}"
              ],
              "path": [
                "transactions",
                "{{transaction_id}}",
                "reverse"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Consolidation API",
      "item": [
        {
          "name": "Health - Live",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{consolidation_url}}/health/live",
              "host": [
                "{{consolidation_url}}"
              ],
              "path": [
                "health",
                "live"
              ]
            }
          }
        },
        {
          "name": "Health - Ready",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{consolidation_url}}/health/ready",
              "host": [
                "{{consolidation_url}}"
              ],
              "path": [
                "health",
                "ready"
              ]
            }
          }
        },
        {
          "name": "Get Daily Balance",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{consolidation_url}}/balance/{{merchant_id}}?date={{balance_date}}",
              "host": [
                "{{consolidation_url}}"
              ],
              "path": [
                "balance",
                "{{merchant_id}}"
              ],
              "query": [
                {
                  "key": "date",
                  "value": "{{balance_date}}",
                  "description": "Opcional. Formato YYYY-MM-DD."
                }
              ]
            }
          }
        },
        {
          "name": "Get Balance Range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{consolidation_url}}/balance/{{merchant_id}}/range?from={{range_from}}&to={{range_to}}",
              "host": [
                "{{consolidation_url}}"
              ],
              "path": [
                "balance",
                "{{merchant_id}}",
                "range"
              ],
              "query": [
                {
                  "key": "from",
                  "value": "{{range_from}}"
                },
                {
                  "key": "to",
                  "value": "{{range_to}}"
                }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "transactions_url",
      "value": "http://localhost:5001"
    },
    {
      "key": "consolidation_url",
      "value": "http://localhost:5002"
    },
    {
      "key": "merchant_id",
      "value": "11111111-1111-1111-1111-111111111111"
    },
    {
      "key": "transaction_id",
      "value": "00000000-0000-0000-0000-000000000000"
    },
    {
      "key": "jwt_token",
      "value": "cole-seu-token-jwt-aqui"
    },
    {
      "key": "balance_date",
      "value": "2026-04-28"
    },
    {
      "key": "range_from",
      "value": "2026-04-01"
    },
    {
      "key": "range_to",
      "value": "2026-04-28"
    }
  ]
}
